# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/event-ticket-platform
DB_USERNAME=postgres
DB_PASSWORD=your_database_password
DB_DRIVER=org.postgresql.Driver

# Server Configuration
SERVER_PORT=8080
SERVER_ADDRESS=0.0.0.0

# JPA Configuration
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# OAuth2 Resource Server Configuration
OAUTH2_ISSUER_URI=http://localhost:9090/realms/event-ticket-platform
OAUTH2_JWK_SET_URI=http://localhost:9090/realms/event-ticket-platform/protocol/openid-connect/certs

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Spring Application Name
SPRING_APPLICATION_NAME=tickets
