    private AdminOrganizerDto convertToAdminOrganizerDto(User organizer) {
        var events = eventRepository.findByOrganizerId(organizer.getId(), Pageable.unpaged()).getContent();
        
        int totalEventsCreated = events.size();
        
        int totalTicketsSold = events.stream()
                .mapToInt(event -> ticketRepository.findByEventOrganizerIdAndEventId(
                        organizer.getId(), event.getId(), Pageable.unpaged()).getContent().size())
                .sum();
        
        double totalRevenue = events.stream()
                .mapToDouble(event -> {
                    var tickets = ticketRepository.findByEventOrganizerIdAndEventId(
                            organizer.getId(), event.getId(), Pageable.unpaged()).getContent();
                    return tickets.stream()
                            .mapToDouble(ticket -> ticket.getTicketType().getPrice())
                            .sum();
                })
                .sum();
        
        return AdminOrganizerDto.builder()
                .organizerId(organizer.getId())
                .organizerName(organizer.getName())
                .organizerEmail(organizer.getEmail())
                .createdAt(organizer.getCreatedAt())
                .totalEventsCreated(totalEventsCreated)
                .totalTicketsSold(totalTicketsSold)
                .totalRevenue(totalRevenue)
                .totalProfit(totalRevenue) // Assuming profit = revenue for now
                .isActive(true) // Assuming all organizers are active
                .build();
    }

    private AdminUserManagementDto convertToAdminUserManagementDto(User user) {
        int eventsAttended = user.getAttendingEvents().size();
        int ticketsPurchased = 0; // This would need to be calculated from ticket purchases
        
        return AdminUserManagementDto.builder()
                .userId(user.getId())
                .name(user.getName())
                .email(user.getEmail())
                .role(user.getRole() != null ? user.getRole().getName().toString() : "UNKNOWN")
                .createdAt(user.getCreatedAt())
                .lastLogin(null) // Not tracked in current implementation
                .isActive(true) // Assuming all users are active
                .isBlocked(false) // Assuming no users are blocked
                .eventsAttended(eventsAttended)
                .ticketsPurchased(ticketsPurchased)
                .build();
    }

